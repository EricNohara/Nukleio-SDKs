{
  "name": "nukleio-sdks",
  "version": "0.0.0",
  "private": true,
  "description": "Official SDKs for the Nukleio public API",
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
